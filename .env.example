# .env.example - Configuración para el bot de clima

# Ruta al archivo donde se almacenan las ciudades favoritas
CIUDADES_FILE=ciudades_favoritas.json

# API Key de OpenWeatherMap
OPENWEATHERMAP_API_KEY=tu_api_key_aqui

# Token del bot de Telegram
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# ID del chat al que enviar mensajes automáticamente (opcional)
TELEGRAM_CHAT_ID=tu_chat_id_aqui
